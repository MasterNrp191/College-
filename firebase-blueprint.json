{
  "entities": {
    "Student": {
      "title": "Student Profile",
      "description": "Stores student profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the student" },
        "email": { "type": "string", "description": "Email address" },
        "program": { "type": "string", "description": "Academic program" },
        "registrationNumber": { "type": "string", "description": "College registration number" },
        "role": { "type": "string", "enum": ["student", "admin", "editor", "bursar"], "description": "User role" },
        "approved": { "type": "boolean", "description": "Approval status" },
        "feesRemaining": { "type": "number", "description": "Remaining fees to be paid" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "lastLogin": { "type": "number", "description": "Timestamp of last login" }
      },
      "required": ["uid", "name", "email", "role", "approved"]
    },
    "Result": {
      "title": "Academic Result",
      "description": "Stores academic performance for a student.",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string", "description": "UID of the student" },
        "courseName": { "type": "string", "description": "Name of the course" },
        "courseCode": { "type": "string", "description": "Course code" },
        "grade": { "type": "string", "description": "Grade earned" },
        "semester": { "type": "string", "description": "Semester" },
        "year": { "type": "string", "description": "Academic year" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["studentUid", "courseName", "grade", "semester", "year"]
    },
    "Timetable": {
      "title": "Timetable",
      "description": "Stores academic timetables.",
      "type": "object",
      "properties": {
        "program": { "type": "string", "description": "Academic program" },
        "year": { "type": "string", "description": "Academic year" },
        "semester": { "type": "string", "description": "Semester" },
        "fileUrl": { "type": "string", "description": "URL to the timetable file" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["program", "year", "semester", "fileUrl"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Stores college announcements.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the announcement" },
        "content": { "type": "string", "description": "Content of the announcement" },
        "category": { "type": "string", "description": "Category (e.g., Academic, Event)" },
        "date": { "type": "number", "description": "Timestamp of announcement" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["title", "content", "category", "date"]
    },
    "ProfilePictureRequest": {
      "title": "Profile Picture Request",
      "description": "Stores requests for profile picture updates.",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string", "description": "UID of the student" },
        "imageUrl": { "type": "string", "description": "URL of the profile picture" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Status of the request" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["studentUid", "imageUrl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "Student",
      "description": "User profiles and roles"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Academic results for students"
    },
    "/timetables/{timetableId}": {
      "schema": "Timetable",
      "description": "Academic timetables"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "College announcements"
    },
    "/profile_picture_requests/{requestId}": {
      "schema": "ProfilePictureRequest",
      "description": "Profile picture requests for students"
    }
  }
}
